{
  "manifest_version": 2,
  "name": "Nightly Countdown",
  "version": "1.0",
  "description": "Shows days until the next Firefox Nightly cycle as a partial green ring.",

  "permissions": [
    "https://whattrainisitnow.com/*"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "browser_action": {
    "default_icon": "icons/addon-icon.svg",
    "default_title": "Nightly Countdown",
    "default_popup": "popup/popup.html"
  },

  "homepage_url": "https://github.com/calixteman/nightly_countdown_addon",

  "browser_specific_settings": {
    "gecko": {
      "id": "@nightly_countdown",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "icons": {
    "48": "icons/addon-icon.svg",
    "96": "icons/addon-icon.svg"
  }
}
